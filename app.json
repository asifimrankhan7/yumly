{
  "expo": {
    "name": "yumly",
    "slug": "yumly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yumly",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aik.yumly"
    },
    "android": {
      "package": "com.aik.yumly",
      "adaptiveIcon": {
        "backgroundColor": "#0E0E10",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "runtimeVersion": "1.0.0",
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "baseUrl": "/yumly"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LOGO1.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#1A1C1E",
          "dark": {
            "backgroundColor": "#1A1C1E"
          }
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af166135-3a0d-4a63-b90d-26c2cdd82fff"
      }
    },
    "owner": "aik7"
  }
}
